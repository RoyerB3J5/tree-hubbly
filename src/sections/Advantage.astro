---
type Translations = typeof import("../i18n/en").default;
type AdvantageContent = Translations["caseStudies"]["advantage"];
interface Props {
  content: AdvantageContent;
}
const { content } = Astro.props;
---
<section class="container-full bg-white flex flex-col md:flex-row justify-between items-start md:items-center py-10 md:py-20 lg:py-30 gap-8 md:gap-6 lg:gap-0">
  <h2 set:html={content.title} class="text-[32px] md:text-[48px] font-bold leading-[130%] md:leading-[120%] text-primary animation-fade-right"></h2>
  <div class="flex flex-col justify-center items-start gap-4 md:gap-8 max-w-none md:max-w-[50%] animation-fade-left">
    {
      content.descriptions.map((desc)=>(
        <p set:html={desc} class="text-[12px] md:text-[14px] text-primary leading-[150%] font-normal"></p>
      ))
    }
  </div>
</section>