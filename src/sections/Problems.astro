---
import type { SystemPage } from "../types/system.type";

type ProblemSection = SystemPage["problem"];
interface Props {
  content: ProblemSection;
}
const { content } = Astro.props as Props;
const colsMap : Record<number, string> = {
  3: "md:grid-cols-1",
  4: "md:grid-cols-2",
}
const cols = colsMap[content?.items?.length ?? 1] || "md:grid-cols-1";
---
<section class="w-full flex justify-center items-center bg-back">
  <div class="container-full flex flex-col md:flex-row justify-center items-center gap-10 md:gap-8 lg:gap-16 py-10 md:py-20 lg:py-30">
      <div class={`flex flex-col justify-center items-start gap-8 w-full ${content?.imageContent.description ? 'md:w-[48%]' : 'md:w-[60%]'}`}>
        <h2 set:html={content?.title} class="text-[32px] md:text-[48px] text-primary font-bold leading-[130%] md:leading-[120%] text-start animation-zoom-in-3"></h2>
        <p set:html={content?.description} class={`text-primary text-[12px] md:text-[14px] leading-[150%] font-normal text-start w-full ${content?.imageContent.description ? 'md:w-[85%]' : 'md:w-[65%]'} animation-zoom-in-3`}></p>
        <div class={`grid grid-cols-1 ${cols} gap-4 md:gap-6 justify-center items-stretch w-full` }>
          {
            content?.items.map((item)=>( 
              <div class="w-full flex justify-start items-start p-4 md:p-6 rounded-2xl md:rounded-3xl border border-[#DEDEDE] bg-white gap-4 h-full animation-zoom-in-3">
                <img src={`/images/${item.icon}.svg`} alt={item.title} class="w-6 h-6" width="24" height="24">
                <div class="flex flex-col justify-center items-start gap-2 flex-1">
                  <h3 set:html={item.title} class="text-[14px] md:text-[16px] font-bold leading-[150%] text-primary"></h3>
                  <p set:html={item.description} class="text-primary text-[12px] md:text-[14px] leading-[150%] font-normal flex-1"></p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      {
        content?.imageContent.description ? (
          <div class={`flex justify-start items-end w-full md:w-[52%] aspect-343/375 md:aspect-square h-auto p-4 md:p-8 lg:p-12.5 rounded-2xl: rounded-3xl overflow-hidden relative container-image-fade`}>
            <img src={`/images/${content?.imageContent.image}.webp`} alt={content?.imageContent.description} class="w-full h-full absolute inset-0 object-cover object-top md:object-center image-fade">
            <div class="absolute w-full h-full inset-0 z-2 back-hero"></div>
            <p class="text-white text-[12px] md:text-[16px] leading-[150%] font-normal z-5 text-start">{content?.imageContent.description}</p>
          </div>
        ) : (
          <div class={`flex justify-center items-center w-full md:w-[40%] aspect-486/588 h-auto relative  overflow-hidden container-image-fade `}>
            <img src={`/images/${content?.imageContent.image}.webp`} alt={content?.imageContent.image} class="w-full h-full absolute inset-0 object-cover object-center  rounded-2xl md:rounded-3xl hover:scale-125 transition-transform duration-300 ease-in-out">
          </div>
        )
      }
  </div>
</section>