---
import type { SolutionPage } from "../types/system.type";

type StadisticSection = SolutionPage["stadistic"];
interface Props {
  content: StadisticSection;
}
const { content } = Astro.props as Props;
---
<section class={`w-full flex ${content?.different ? 'bg-primary' : 'bg-white'} justify-center items-center `}>
  <div class={`container-full flex flex-col md:flex-row ${content?.different ? 'justify-start gap-12' : 'justify-between gap-8 md:gap-6 lg:gap-0'}  items-center py-10 md:py-20 lg:py-30`}>
    <div class={`w-full md:w-[55%] lg:w-[45%] flex flex-col justify-center items-start gap-8 md:gap-12 ${content?.different ? 'text-white order-2' : 'text-primary order-1'}`}>
      <div class="flex flex-col justify-center items-start gap-8">
        <h2 set:html={content?.title} class={`text-[32px] md:text-[48px] font-bold leading-[120%] ${content?.different ? 'text-white' : 'text-primary animation-zoom-in-3'}`}></h2>
        <p class={`animation-zoom-in-3 text-[12px] md:text-[14px] font-normal leading-[150%] ${content?.different ? 'text-white' : 'text-primary'} w-full md:w-[80%]`}>{content?.description}</p>
      </div>
      {
        content?.items && ( 
          <div class="flex flex-col justify-center items-start gap-6">
            {
              content.items.map((item)=>( 
                <div class="flex justify-start items-center gap-4 animation-zoom-in-3">
                  <img src="/images/check.svg" alt="Check icon" width="24" height="24" class="w-6 h-6">
                  <p class="text-[14px] font-normal leading-[150%] text-paragraph">{item}</p>
                </div>
              ))
            }
          </div>
        )
      }
      {
        content?.lists && (
          <div class="w-full md:w-auto flex justify-between md:justify-start items-start gap-0 md:gap-12">
            {
              content?.lists?.map((item)=>( 
                <div class="flex flex-col justify-center items-center lg:items-start gap-1 animation-zoom-in-3">
                  <h3 class="text-[20px] md:text-[32px] font-bold leading-[140%] md:leading-[130%] text-primary">{item.title}</h3>
                  <p class="text-[12px] md:text-[14px] font-normal leading-[150%] text-primary text-center lg:text-start">{item.description}</p>
                </div>
              ))
            }
          </div>
        )
      }
      
    </div>
    <div class={`w-full md:w-[45%] lg:w-auto h-auto bg-[#0B0F1D] rounded-2xl md:rounded-3xl p-7.5 md:p-4 lg:p-12.5 container-image-fade ${content?.different ? 'order-1 border border-[#263A4B] box-border' : 'order-2'}`} >
      <img src={`/images/${content?.image}.webp`} alt={content?.title} width="464" height="349" class="w-full h-auto hover:scale-125 transition-transform duration-300 ease-in-out" decoding="async" loading="lazy">
    </div>
  </div>
</section>