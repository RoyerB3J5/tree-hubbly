---
type Translations = typeof import("../../i18n/en").default;
type CompaniesContent = Translations["main"]["companies"];
interface Props {
  content: CompaniesContent;
}
const { content } = Astro.props as Props;
---
<section class="w-full flex justify-center items-center bg-primary py-10 md:py-20 lg:py-30 px-5 xl:px-0">
  <div class="w-full max-w-screen xl:max-w-7xl  bg-primary-2 py-10 md:py-20 rounded-3xl flex justify-center items-center back-content ">
    <div class="w-full md:w-[85%] lg:w-[80%] flex flex-col justify-center items-center gap-8 md:gap-12 px-4 md:px-0">
      <h2 set:html={content.title} class="text-paragraph text-[32px] md:text-[36px] lg:text-[48px] font-bold leading-[120%] text-center animation-zoom-in"></h2>
      <div class="w-full flex justify-between md:justify-center items-center md:items-start gap-4 md:gap-10 lg:gap-18 py-6 md:py-10 border-t-[1.5px] border-b-[1.5px] border-secondary px-4 md:px-0 animation-zoom-in">
        {
          content.tags.map((tag)=>( 
            <div class="flex justify-center items-center gap-1.25">
              <img src={`/images/${tag.image}.svg`} alt={tag.label} width="24" height="24" class="hidden md:block w-6 h-6">
              <p class="text-[14px] text-paragraph font-bold md:font-medium leading-[150%]">{tag.label}</p>
            </div>
          ))
        }
      </div>
      <div class="flex w-full flex-col md:flex-row justify-center items-center gap-6">
        <div class="w-full md:w-1/2 flex flex-col justify-center items-center gap-6 md:gap-8">
          <p class="text-paragraph font-normal leading-[150%] text-[12px] md:text-[14px] animation-zoom-in text-center">{content.content}</p>
          <div class="flex flex-col justify-center items-start gap-4 md:gap-6">
            {
              content.items.map((item)=>(
                <div class="flex justify-start items-center gap-4 animation-zoom-in">
                  <img src="/images/check.svg" alt="Check" width="24" height="24" class="w-6 h-6">
                  <p class="text-paragraph font-normal leading-[150%] text-[12px] md:text-[14px]">{item}</p>
                </div>
              ))
            }
          </div>
        </div>
        <div class="w-full md:w-1/2 relative rounded-lg lg:rounded-2xl aspect-130/79 md:aspect-486/296 h-auto overflow-hidden container-image-fade">
          <img src="/images/companies.webp" alt="Companies TreeHubly" width="700" height="467" class="w-full h-full object-cover object-center image-fade hover:scale-125 duration-300 ease-in-out transition-all" style="animation-delay: 0.2s;">
        </div>
      </div>
      <div class="w-full md:w-[85%] lg:w-[85%] 3xl:w-[70%] rounded-lg md:rounded-3xl border-[1.5px] border-[#263A4B] p-4 md:p-8 lg:py-16 flex justify-center items-center animation-zoom-in">
        <p set:html={content.review} class="text-paragraph text-[14px] md:text-[18px] leading-[150%] font-bold text-center"></p>
      </div>
    </div>
  </div>
</section>
