---
import Button from "../../components/Button.astro";

type Translations = typeof import("../../i18n/en").default;
type ResultsContent = Translations["main"]["results"];
interface Props {
  content: ResultsContent;
}
const { content } = Astro.props as Props;
---
<section class="w-full flex flex-col justify-center items-center gap-8 lg:gap-14 py-10 md:py-20 lg:py-30">
  <div class="container-full flex flex-col md:flex-row justify-between items-center gap-8 md:gap-0">
    <div class="flex flex-col justify-center items-start gap-8">
      <h2 set:html={content.title} class="text-[32px] md:text-[48px] font-bold text-primary leading-[130%] md:leading-[120%] "></h2>
      <p set:html={content.description} class="text-primary text-[12px] md:text-[14px] font-normal leading-[150%]"></p>
    </div>
    <div class="flex flex-col md:flex-row justify-center items-center gap-4 md:gap-6 w-full md:w-auto">
        {
          content.buttons.map((button) => (
            <Button
              text={button.label}
              href={button.href}
              extraBtnClass={button.styleButton}
              textClass={button.styleLabel}
            />))
        }
      </div>
  </div>
  <div class="carousel-container">
    <div class="carousel-track">
      {
        // Duplicar items 3 veces para crear el loop infinito suave
        [...content.items, ...content.items, ...content.items].map((item, index)=>( 
          <div class="carousel-item aspect-384/647 h-auto py-6 pl-4 pr-14 md:py-10 md:pl-10 md:pr-20 flex flex-col justify-between items-start relative rounded-3xl overflow-hidden shrink-0">
            <img src={`/images/${item.image}.webp`} alt={item.title} width="384" height="647" class="w-full h-full object-cover object-center absolute inset-0 -z-20" decoding="async" loading="lazy"/>
            <div class="absolute w-full h-full inset-0 -z-10 back-result"></div>
            <div class="flex flex-col justify-center items-start gap-4">
              <div class="bg-secondary py-1 px-4 flex justify-center items-center rounded-full">
                <p class="text-primary text-[14px] font-semibold leading-[150%] uppercase">{item.tag}</p>
              </div>
              <h3 class="text-paragraph text-[24px] font-bold leading-[140%]">{item.title}</h3>
            </div>
            <div class="flex flex-col justify-center items-start gap-6 md:gap-10">
              <div class="flex flex-col justify-center items-start gap-4">
                {
                  item.numbers.map((number) => ( 
                    <div class="flex flex-col justify-center items-start gap-2">
                      <p class="text-secondary text-[48px] font-bold leading-[120%]">{number.value}</p>
                      <p class="text-paragraph text-[12px] md:text-[14px] font-normal leading-[150%]">{number.description}</p>
                    </div>
                  ))
                }
              </div>
              <div class="flex flex-col justify-center items-start gap-2 md:gap-4">
                {
                  item.description.map((content)=>( 
                    <div class="flex justify-start items-center gap-1 ">
                      <img src={`/images/${content.icon}.svg`} alt={content.label} width="24" height="24" decoding="async" loading="lazy" class="w-6 h-6"/>
                      <p class="text-[12px] md:text-[14px] font-normal leading-[150%] text-paragraph">{content.label}</p>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .carousel-container {
    width: 100%;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
    will-change: transform;
  }

  /* < 640px — 1 ítem visible */
  .carousel-item {
    flex: 0 0 calc(100vw - 1.5rem);
  }

  /* sm → md (640px–767px) — 2 ítems visibles */
  @media (min-width: 640px) {
    .carousel-item {
      flex: 0 0 calc((100vw - 1.5rem) / 2);
    }
  }

  /* md → lg (768px–1023px) — 3 ítems visibles */
  @media (min-width: 1025px) {
    .carousel-item {
      flex: 0 0 calc((100vw - 2 * 1.5rem) / 3);
    }
  }

  /* lg en adelante (1024px+) — 4 ítems visibles */
  @media (min-width: 1300px) {
    .carousel-item {
      flex: 0 0 calc((100vw - 3 * 1.5rem) / 4);
    }
  }

  @keyframes scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(var(--scroll-distance)); }
  }
</style>

<script>
  const track = document.querySelector('.carousel-track') as HTMLElement;
  const originalCount = track.children.length / 3; // items triplicados

  function setupCarousel() {
    // El offsetLeft del primer ítem de la 2da copia es exactamente
    // cuánto hay que mover para que parezca un loop perfecto
    const firstItemSecondCopy = track.children[originalCount] as HTMLElement;
    const distance = firstItemSecondCopy.offsetLeft;

    track.style.setProperty('--scroll-distance', `-${distance}px`);

    // Reiniciar la animación con el nuevo valor
    track.style.animation = 'none';
    track.offsetHeight; // forzar reflow
    track.style.animation = 'scroll 60s linear infinite';
  }

  setupCarousel();

  // Recalcular si cambia el tamaño de ventana (responsive)
  window.addEventListener('resize', setupCarousel);
</script>