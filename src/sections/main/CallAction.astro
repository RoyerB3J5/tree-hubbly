---
import Button from "../../components/Button.astro";

type Translations = typeof import("../../i18n/en").default;
type CallContent = Translations["systems"]["structured-lead-engine"]["call"];
interface Props {
  content: CallContent;
}
const { content } = Astro.props as Props;
---

<section
  data-curtain-reveal
  class="bg-secondary w-full flex justify-center items-center relative overflow-hidden"
>
  <div class="w-full max-w-screen xl:max-w-7xl px-5 xl:px-0 flex flex-col justify-start items-start md:items-center gap-8 pt-10 md:pt-20 lg:pt-30 z-20 h-full pb-20 md:pb-40 lg:pb-55.75 3xl:pb-68">
    <h2
      set:html={content.title}
      class="text-[32px] md:text-[48px] font-bold leading-[120%] text-primary text-start md:text-center animation-up-fast-2"
    ></h2>
    <p
      set:html={content.description}
      class="text-[12px] md:text-[14px] leading-[150%] font-normal text-primary text-start md:text-center animation-up-fast-2"
    ></p>
    {content.items &&
      <div
        class={`flex-col md:flex-row justify-center items-start md:items-center gap-2 md:gap-4 ${content.items.length > 0 ? "flex" : "hidden"}`}
      >
        {content.items.map((item) => (
          <div class="flex justify-center items-center gap-2 animation-up-fast-2">
            <img
              src="/images/check-3.svg"
              alt="check Azul"
              width="24"
              height="24"
              decoding="async"
              loading="lazy"
              class="w-6 h-6"
            />
            <p class="text-[12px] md:text-[14px] font-normal leading-[150%] text-primary">
              {item}
            </p>
          </div>
        ))}
      </div>
    }
    <div class="w-full md:w-auto flex flex-col md:flex-row justify-center items-center gap-4 md:gap-6 animation-up-fast-2">
      {content.buttons.map((button) => (
        <Button
          text={button.label}
          href={button.href}
          extraBtnClass={button.styleButton}
          textClass={button.styleLabel}
        />
      ))}
    </div>
  </div>
  <img
    src="/images/letter.webp"
    alt="Letter"
    class="absolute bottom-0 right-0 w-full h-full object-contain object-center translate-y-1/2 opacity-30 animation-up-fast-3"
    width="1440"
    height="308"
    decoding="async"
    loading="lazy"
  />
</section>

<script is:inline>
  function initCurtainEffect() {
    var curtainSections = document.querySelectorAll("[data-curtain-reveal]");

    curtainSections.forEach(function (section) {
      // Buscar la sección anterior con data-curtain más cercana (hacia arriba en el DOM)
      var prevSection = null;
      var current = section.previousElementSibling;
      
      while (current) {
        if (current.hasAttribute('data-curtain')) {
          prevSection = current;
          break;
        }
        current = current.previousElementSibling;
      }

      // La sección anterior es el "telón": se pone encima del CallAction
      if (prevSection) {
        prevSection.style.position = "relative";
        prevSection.style.zIndex = "2";
        console.log("Telón encontrado:", prevSection);
      } else {
        console.log("No se encontró sección con data-curtain");
      }

      // CallAction queda debajo, esperando ser revelado
      section.style.position = "relative";
      section.style.zIndex = "1";

      // Estado inicial: completamente oculto desde arriba
      section.style.clipPath = "inset(100% 0 0 0)";

      var rafId = 0;

      function updateCurtain() {
        var vh = window.innerHeight;
        var progress = 0;

        if (prevSection) {
          // prevBottom = vh  → progress = 0 → invisible
          // prevBottom = 0   → progress = 1 → completamente visible
          var prevBottom = prevSection.getBoundingClientRect().bottom;
          progress = Math.max(0, Math.min(1, 1 - prevBottom / vh));
        } else {
          var rect = section.getBoundingClientRect();
          progress = Math.max(0, Math.min(1, (vh - rect.top) / vh));
        }

        var clipTop = ((1 - progress) * 100).toFixed(2);
        section.style.clipPath = "inset(" + clipTop + "% 0 0 0)";
      }

      function onScroll() {
        cancelAnimationFrame(rafId);
        rafId = requestAnimationFrame(updateCurtain);
      }

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", updateCurtain, { passive: true });

      updateCurtain();
    });
  }

  // Soporte para Astro View Transitions
  document.addEventListener("astro:page-load", initCurtainEffect);

  // Ejecución en carga inicial
  initCurtainEffect();
</script>