---
import en from '../../../i18n/en';
import es from '../../../i18n/es';
import Layout from '../../../layouts/Layout.astro';
import CallAction from '../../../sections/main/CallAction.astro';
import Hero from '../../../sections/main/Hero.astro';
import Resources from '../../../sections/Resources.astro';
import type { Language } from '../../../types/language.type';
export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

export const defaultRedirect = '/en';

const lang = Astro.params.lang as Language;
const translations = { es, en };
const t = translations[lang];
---
<Layout lang={lang} t={t}>
  <Hero content={t.resource.hero} />
  <Resources content={t.resource.resources} />
  <CallAction content={t.resource.call} />
</Layout>