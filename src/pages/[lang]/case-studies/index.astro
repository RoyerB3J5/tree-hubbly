---
import en from '../../../i18n/en';
import es from '../../../i18n/es';
import Layout from '../../../layouts/Layout.astro';
import Advantage from '../../../sections/Advantage.astro';
import Business from '../../../sections/Business.astro';
import BannerImages from '../../../sections/main/BannerImages.astro';
import CallAction from '../../../sections/main/CallAction.astro';
import Hero from '../../../sections/main/Hero.astro';
import System from '../../../sections/System.astro';
import Transformation from '../../../sections/Transformation.astro';
import Transformation2 from '../../../sections/Transformation2';
import type { Language } from '../../../types/language.type';
export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

export const defaultRedirect = '/en';

const lang = Astro.params.lang as Language;
const translations = { es, en };
const t = translations[lang];
---
<Layout lang={lang} t={t}>
  <Hero content={t.caseStudies.hero} />
  <Business content={t.caseStudies.business} />
  <System content={t.caseStudies.system} />
  <Transformation2 content={t.caseStudies.transformation.info} client:load/>
  <Transformation content={t.caseStudies.transformation} />
  <BannerImages content={t.caseStudies.bannerImage} />
  <Advantage content={t.caseStudies.advantage} />
  <CallAction content={t.caseStudies.call} />
</Layout>